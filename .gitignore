# ====================================================================
# GITIGNORE FOR /opt/vchanel - FINAL VERSION WITH REACT EXCLUSION
# ====================================================================

# 1. EXCLUDE the 'old version' directory completely
old version/

# 2. EXCLUDE all other non-required files in the root
*.*

# 3. EXCLUDE the node_modules folder from the React project (myapp)
#    This is essential for any Node.js/React/npm project!
myapp/node_modules/

# 4. EXCLUDE most content inside the 'fastback' directory
#    (Ensures all subdirectories inside fastback are ignored)
fastback/*/

# 5. EXCEPTION: NEGATE the ignore rules for the specific directories we want to keep
#    This makes Git track the two required application folders inside fastback.
!fastback/cam1_app_1/
!fastback/cam2_app_1/

# 6. EXCEPTION: NEGATE the ignore rules for the required file types in ANY directory
!*.py
!*.env
!*.properties
!*.pt
!*.gitignore