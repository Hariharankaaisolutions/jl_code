# ====================================================================
# GITIGNORE FOR /opt/vchanel
# Goal: Include all directories except 'old version', and exclude most
#       content inside 'fastback'.
# ====================================================================

# 1. EXCLUDE the 'old version' directory completely
old version/

# 2. EXCLUDE all other non-required files in the root
#    (e.g., .log files, temporary files, etc. that aren't scripts/config)
*.*

# 3. EXCLUDE most content inside the 'fastback' directory
#    (This line ensures all subdirectories inside fastback are ignored)
fastback/*/

# 4. EXCEPTION: NEGATE the ignore rules for the specific directories we want to keep
#    This makes Git track the two required application folders inside fastback.
!fastback/cam1_app_1/
!fastback/cam2_app_1/

# 5. EXCEPTION: NEGATE the ignore rules for the required file types in ANY directory
#    This overrides the '*.*' rule above for files we need.
!*.py
!*.env
!*.properties
!*.pt
!*.gitignore